# cp "/Users/jaydenkaiyang/Documents/Programming Projects/Smart Parking SG/server/config/nginx.config" /opt/homebrew/etc/nginx/nginx.conf

# Top-level required
worker_processes  1;

events {
    worker_connections  1024;
}

http {
    upstream my_app {
        least_conn; # least connection algorithm

        server 127.0.0.1:3000;
        server 127.0.0.1:3001;
        server 127.0.0.1:3002;
        server 127.0.0.1:3003;
        server 127.0.0.1:3004;
        #server 127.0.0.1:3005;
        #server 127.0.0.1:3006;
        #server 127.0.0.1:3007;
        #server 127.0.0.1:3008;
        #server 127.0.0.1:3009;
        
    }

    server {
        listen 8080;

        location / {
            proxy_pass http://my_app;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection 'upgrade';
            proxy_set_header Host $host;
            proxy_cache_bypass $http_upgrade;
            
            # Timeouts for backend
            proxy_connect_timeout 2s;  # wait max 2s to connect
            proxy_send_timeout 3s;     # max time to send request
            proxy_read_timeout 3s;     # max time to wait for response
        }
    }
}